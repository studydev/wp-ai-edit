#. Plugin Name
#: wp-ai-edit.php
msgid "WP AI Edit"
msgstr "Hemtory AI Editor"

#: includes/class-admin-settings.php
msgid "API Endpoint URL"
msgstr "API 엔드포인트 URL"

#: includes/class-admin-settings.php
msgid "API Key"
msgstr "API 키"

#: includes/class-admin-settings.php
msgid "Test Connection"
msgstr "연결 테스트"

#: includes/class-admin-settings.php
msgid "Model"
msgstr "모델"

#: includes/class-admin-settings.php
msgid "System Prompt Settings"
msgstr "시스템 프롬프트 설정"

#: includes/class-admin-settings.php
msgid "Customize the system prompts for each AI action. Leave empty to use the default prompt."
msgstr "각 AI 액션의 시스템 프롬프트를 편집합니다. 비워두면 기본 프롬프트가 사용됩니다."

#: includes/class-admin-settings.php
msgid "Tail Prompt (Response Format)"
msgstr "꼬리 프롬프트 (응답 형식)"

#: includes/class-admin-settings.php
msgid "The tail prompt is automatically appended to every system prompt (except SEO Helper) to ensure the AI response is formatted in Gutenberg-compatible HTML."
msgstr "꼬리 프롬프트는 SEO Helper를 제외한 모든 시스템 프롬프트에 자동으로 추가되어, AI 응답이 Gutenberg 호환 HTML 형식으로 반환되도록 합니다."

#: includes/class-admin-settings.php
msgid "Tail Prompt"
msgstr "꼬리 프롬프트"

#: includes/class-admin-settings.php
msgid "This prompt is appended to all system prompts except SEO Helper, instructing the AI to respond in Gutenberg-compatible HTML."
msgstr "이 프롬프트는 SEO Helper를 제외한 모든 시스템 프롬프트에 추가되어, AI가 Gutenberg 호환 HTML로 응답하도록 지시합니다."

#: includes/class-admin-settings.php
msgid "Reset to default"
msgstr "기본값으로 초기화"

#: includes/class-admin-settings.php
msgid "View Full Prompt"
msgstr "전체 프롬프트 보기"

#: includes/class-admin-settings.php
msgid "[Tail Prompt]"
msgstr "[꼬리 프롬프트]"

#: includes/class-admin-settings.php
msgid "Testing connection..."
msgstr "연결 테스트 중..."

#: includes/class-admin-settings.php
msgid "Connection failed:"
msgstr "연결 실패:"

#: includes/class-admin-settings.php
msgid "Reset this prompt to default?"
msgstr "이 프롬프트를 기본값으로 초기화하시겠습니까?"

#: includes/class-prompt-manager.php
msgid "Your Command"
msgstr "자유 명령"

#: includes/class-prompt-manager.php
msgid "My Style"
msgstr "내 스타일"

#: includes/class-prompt-manager.php
msgid "Highlight"
msgstr "하이라이트"

#: includes/class-prompt-manager.php
msgid "Summarize"
msgstr "요약"

#: includes/class-prompt-manager.php
msgid "Write Analogy"
msgstr "비유로 쓰기"

#: includes/class-prompt-manager.php
msgid "Fix Grammar"
msgstr "문법 교정"

#: includes/class-prompt-manager.php
msgid "SEO Helper"
msgstr "SEO 도우미"

#: includes/class-rest-api.php
msgid "API is not configured. Please set up the API in WP AI Edit settings."
msgstr "API가 설정되지 않았습니다. WP AI Edit 설정에서 API를 구성해 주세요."

#: includes/class-rest-api.php
msgid "API is not configured."
msgstr "API가 설정되지 않았습니다."

#: includes/class-rest-api.php
msgid "Too many requests. Please wait a few seconds before trying again."
msgstr "요청이 너무 많습니다. 잠시 후 다시 시도해 주세요."

#: includes/class-openai-client.php
msgid "Failed to encode request body."
msgstr "요청 본문 인코딩에 실패했습니다."

#: includes/class-openai-client.php
msgid "Failed to initialize cURL."
msgstr "cURL 초기화에 실패했습니다."

#. translators: 1: error number, 2: error message
#: includes/class-openai-client.php
msgid "cURL error (%1$d): %2$s"
msgstr "cURL 오류 (%1$d): %2$s"

#. translators: %d: HTTP status code
#: includes/class-openai-client.php
msgid "API error: HTTP %d"
msgstr "API 오류: HTTP %d"

#. translators: 1: HTTP status code, 2: response body
#: includes/class-openai-client.php
msgid "HTTP %1$d: %2$s"
msgstr "HTTP %1$d: %2$s"

#: includes/class-openai-client.php
#: includes/class-admin-settings.php
msgid "Connection successful!"
msgstr "연결 성공!"

#. JS strings — editor UI
#: src/editor/plugin.js
msgid "AI Edit"
msgstr "AI 편집"

#: src/editor/plugin.js
msgid "No text content in the selected block."
msgstr "선택된 블록에 텍스트 내용이 없습니다."

#: src/editor/result-popover.js
msgid "Generating…"
msgstr "생성 중…"

#: src/editor/result-popover.js
